FROM debian:13.4

RUN apt-get update
RUN apt-get install -y nodejs npm python3 python3-pip ripgrep ffmpeg gcc python3-dev libffi-dev ca-certificates curl
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y gh

COPY . /opt/hermes
WORKDIR /opt/hermes

RUN pip install -e ".[all]" --break-system-packages
RUN npm install
# Disable TLS verification for Playwright download only (required behind corporate MITM proxy)
RUN NODE_TLS_REJECT_UNAUTHORIZED=0 npx playwright install --with-deps chromium
WORKDIR /opt/hermes/scripts/whatsapp-bridge
RUN npm install

WORKDIR /opt/hermes
RUN cat /opt/hermes/docker/sitecustomize.py >> /usr/lib/python3.13/sitecustomize.py
RUN chmod +x /opt/hermes/docker/entrypoint.sh

ENV HERMES_HOME=/opt/data
RUN mkdir -p /opt/data/bin && chmod -R 777 /opt/data
ENTRYPOINT [ "/opt/hermes/docker/entrypoint.sh" ]